generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String         @id @default(uuid())
  fullName          String
  email             String         @unique
  password          String
  role              String         @default("member")
  profileImage      String?
  createdAt         DateTime       @default(now())
  lastActive        DateTime?
  jumuiaId          String?
  membership_number String?        @unique
  resetCode         String?
  resetCodeExpiry   DateTime?
  
  // EXISTING RELATIONS - Keep as is
  messages          Message[]      @relation("UserMessages") // Added relation name
  Notification      Notification[]
  pledges           Pledge[]
  jumuia            Jumuia?        @relation(fields: [jumuiaId], references: [id])
  
  // NEW CHAT RELATIONS
  messageReactions  MessageReaction[]
  readReceipts      ReadReceipt[]
  mentions          Mention[]
  pinnedMessages    Pin[]
  blockedUsers      BlockedUser[]  @relation("UserBlocks")
  blockedBy         BlockedUser[]  @relation("BlockedBy")
  
  // NEW CHAT FIELDS
  isOnline          Boolean        @default(false)
  lastSeen          DateTime?
}

model Announcement {
  id        String   @id @default(uuid())
  title     String
  content   String
  category  String
  published Boolean  @default(true)
  createdAt DateTime @default(now())
}

model MassProgram {
  id        String            @id @default(uuid())
  date      DateTime
  venue     String
  createdAt DateTime          @default(now())
  songs     MassProgramSong[]
}

model Song {
  id           String            @id @default(uuid())
  title        String
  composer     String?
  massPrograms MassProgramSong[]
}

model MassProgramSong {
  id            String      @id @default(uuid())
  massProgramId String
  songId        String
  type          String
  massProgram   MassProgram @relation(fields: [massProgramId], references: [id], onDelete: Cascade)
  song          Song        @relation(fields: [songId], references: [id])
}

model ContributionType {
  id             String    @id @default(uuid())
  title          String
  description    String?
  amountRequired Float
  deadline       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  jumuiaId       String?
  jumuia         Jumuia?   @relation(fields: [jumuiaId], references: [id])
  pledges        Pledge[]
}

model Pledge {
  id                 String           @id @default(uuid())
  userId             String
  contributionTypeId String
  pendingAmount      Float            @default(0)
  amountPaid         Float            @default(0)
  message            String?
  status             String           @default("PENDING")
  createdByAdmin     Boolean          @default(false)
  approvedById       String?
  approvedAt         DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  contributionType   ContributionType @relation(fields: [contributionTypeId], references: [id], onDelete: Cascade)
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==================== CHAT ROOM MODEL ====================
model ChatRoom {
  id            String         @id @default(uuid())
  name          String         @unique
  description   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  // Relations
  messages      Message[]
  pinnedMessages Pin[]
  
  // NEW FIELDS
  isActive      Boolean        @default(true)
  lastMessageAt DateTime?
}

// ==================== MESSAGE MODEL ====================
model Message {
  id            String         @id @default(uuid())
  content       String         @db.Text
  userId        String
  roomId        String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  // Relations - Fixed with proper relation names
  room          ChatRoom       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade, name: "UserMessages")
  
  // NEW FIELDS FOR RICH FEATURES
  replyToId     String?
  replyTo       Message?       @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies       Message[]      @relation("MessageReplies")
  attachments   Json?          
  isEdited      Boolean        @default(false)
  isDeleted     Boolean        @default(false)
  deletedAt     DateTime?
  deletedBy     String?        
  
  // NEW RELATIONS
  reactions     MessageReaction[]
  mentions      Mention[]
  readReceipts  ReadReceipt[]
  pins          Pin[]

  @@index([userId])
  @@index([roomId])
  @@index([createdAt])
  @@index([replyToId])
  @@index([isDeleted])
}

// ==================== NEW MODEL: Message Reaction ====================
model MessageReaction {
  id            String         @id @default(uuid())
  messageId     String
  userId        String
  reaction      String         
  createdAt     DateTime       @default(now())

  message       Message        @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, reaction])
  @@index([messageId])
  @@index([userId])
}

// ==================== NEW MODEL: Mention ====================
model Mention {
  id            String         @id @default(uuid())
  messageId     String
  userId        String
  isRead        Boolean        @default(false)
  readAt        DateTime?
  createdAt     DateTime       @default(now())

  message       Message        @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId, isRead])
  @@index([messageId])
}

// ==================== NEW MODEL: Read Receipt ====================
model ReadReceipt {
  id            String         @id @default(uuid())
  messageId     String
  userId        String
  readAt        DateTime       @default(now())

  message       Message        @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
  @@index([messageId])
}

// ==================== NEW MODEL: Pin ====================
model Pin {
  id            String         @id @default(uuid())
  messageId     String
  roomId        String
  userId        String
  createdAt     DateTime       @default(now())

  message       Message        @relation(fields: [messageId], references: [id], onDelete: Cascade)
  room          ChatRoom       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, messageId])
  @@index([roomId])
  @@index([messageId])
}

// ==================== NEW MODEL: Blocked User ====================
model BlockedUser {
  id            String         @id @default(uuid())
  userId        String         
  blockedId     String         
  createdAt     DateTime       @default(now())

  user          User           @relation("UserBlocks", fields: [userId], references: [id], onDelete: Cascade)
  blocked       User           @relation("BlockedBy", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([userId, blockedId])
  @@index([userId])
  @@index([blockedId])
}

model Jumuia {
  id            String             @id @default(uuid())
  name          String             @unique
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  contributions ContributionType[]
  members       User[]
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}