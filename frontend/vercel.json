{
  "redirects": [
    {
      "source": "/sitemap.xml",
      "destination": "https://zuca-backend-iw9p.onrender.com/api/sitemap",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/hymn/(.*)",
      "destination": "https://zuca-backend-iw9p.onrender.com/hymn/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        }
      ]
    },
    {
      "source": "/workbox-(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}